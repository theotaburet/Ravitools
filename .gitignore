# =============================================================================
# Ravitools .gitignore
# =============================================================================

# Project tools & caches
.tools/
.mempalace/
*.log

# Node.js
web/*/node_modules/
web/*/.cache/
web/client/dist/
web/server/dist/
*.tsbuildinfo

# Preserve config files
!package.json
!package-lock.json
!tsconfig.json

# GPX / KMZ (binary outputs, not source)
*.gpx
!web/examples/*.gpx
*.kmz

# Icon / font assets (stored elsewhere)
*.svg
*.otf

# Python (MemPalace runtime only)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Environment files
.env

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test / coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
.pytest_cache/
.hypothesis/

# Playwright
web/client/test-results/
web/client/playwright-report/
web/client/e2e-*-report.json
